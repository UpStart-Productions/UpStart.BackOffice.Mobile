    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "ios:sync:dev": "ng build --configuration development && npx cap sync ios",
    "ios:sync:prod": "ng build --configuration production && npx cap sync ios",
